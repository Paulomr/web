# ============================================================
#  Variables de entorno de Crunchy Munch (COPIA este archivo a ".env")
#  El .env real NUNCA se sube a git (está en .gitignore). Estas mismas
#  variables se configuran también en Vercel -> Settings -> Environment Variables.
# ============================================================

# --- Base de datos (MongoDB Atlas) ---
# La cadena de conexión de tu cluster. La consigues en Atlas -> Connect -> Drivers.
MONGODB_URI="mongodb+srv://USUARIO:CLAVE@cluster0.xxxxx.mongodb.net/crunchymunch"

# --- Administración (temporal, para editar el menú) ---
# Una clave larga y secreta inventada por ti (mínimo 24 caracteres al azar).
ADMIN_TOKEN="pon-aqui-una-clave-larga-secreta"

# --- IA de Bearnie (ya existente) ---
ANTHROPIC_API_KEY="sk-ant-..."

# --- Blindaje por IP del bot (opcional, si activas Vercel KV) ---
# KV_REST_API_URL="..."
# KV_REST_API_TOKEN="..."
